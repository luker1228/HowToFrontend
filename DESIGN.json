  "narrative": {
    "northStar": "荧光笔手册（The Highlighter Handbook）",
    "overview": "这套系统像一本摊开的实用手册：奶油纸底、粗黑墨水、荧光笔黄色块标出重点，方块感、硬阴影、留白充足。视觉血脉是 RetroUI（Neo-brutalist）：纯黑描边、0 圆角方块、4px 4px 0 硬偏移阴影、加粗几何字、贴纸式徽章与荧光笔高亮块。但只取 RetroUI 的视觉语言，不取它的营销腔：不喊 \"DESIGNED TO SHIP FAST\" 那种空洞口号，语气保持 PRODUCT.md 的清晰、克制、可信。面向有一点点互联网产品基础的设计师、产品、运营和后端工程师，给他们结构清晰、例子醒目、节奏能呼吸的页面。",
    "keyCharacteristics": [
      "方块感优先：主体组件 0 圆角，只有 pill 徽章/头像走 999px。",
      "高亮黄只做重点：动作、激活态、关键词高亮，绝不铺满区块。",
      "纯黑墨水是承重墙：文字、描边、硬阴影统一用纯黑 #000000。",
      "硬阴影是结构而非氛围：静止时偏平，交互时才抬起。",
      "三套字体分工明确：Archivo Black 做印章式标签，Space Grotesk 做正文与标题，IBM Plex Mono 做元信息与代码。",
      "例子比概念醒目：可交互的演示面承担教学，而不是长段文字。"
    ],
    "rules": [
      { "name": "The One Highlighter Rule", "body": "黄色是信号，不是墙纸。只出现在动作、激活态和需要被一眼看到的关键词上。铺满区块就从重点变成了背景，系统就垮了。", "section": "colors" },
      { "name": "The Pure Ink Rule", "body": "纯黑 #000000 是 Neo-brutalist 身份的承重部分，不要软化成带色调的近黑。文字、描边、硬阴影统一走纯黑；只有大面积深色面才用稍暖的 --nav-dark。", "section": "colors" },
      { "name": "The Accent Discipline Rule", "body": "蓝绿粉紫红薄荷只做点缀，单点使用，不铺区块，更不能取代黄色当主强调。", "section": "colors" },
      { "name": "The Weight-Contrast Rule", "body": "层级靠字号和字重对比建立（相邻档位比例 ≥1.25），不靠装饰性描边或渐变。", "section": "typography" },
      { "name": "The 65ch Rule", "body": "正文段落最大行宽 65ch 左右，超过这个宽度阅读节奏就散了。", "section": "typography" },
      { "name": "The Hard-Shadow Rule", "body": "阴影永远是实心、零模糊、固定偏移（4px 或 6px）的纯黑色块。禁止任何带 blur 的柔和投影、多层投影、彩色 glow。", "section": "elevation" },
      { "name": "The Flat-At-Rest Rule", "body": "静止的面保持平静、贴底。阴影是交互的回应，不是常驻装饰。", "section": "elevation" }
    ],
    "dos": [
      "让例子和可交互演示面承担教学，不要只堆解释段落。",
      "用高亮黄色块（.accent-text）点标题里的一个关键词，形成矩形色块。",
      "保持主体组件 0 圆角；圆角只留给 pill 徽章、头像这类装饰圆形。",
      "用纯黑 #000000 统一文字、描边和硬阴影。",
      "让章节之间有明显呼吸（section 间距 clamp(72px, 7vw, 96px)），不要所有块一样紧。",
      "正文行宽控制在 65ch 左右，层级靠字号/字重对比建立。",
      "给每个可交互元素完整的 hover / focus-visible / active 状态；focus 用 3px 纯黑外框。",
      "尊重 prefers-reduced-motion：交互动效在用户偏好下退化为瞬切。"
    ],
    "donts": [
      "不要把黄色铺满整个区块当背景（The One Highlighter Rule）。",
      "不要把纯黑软化为带色调的近黑（The Pure Ink Rule）。",
      "不要用 border-left / border-right 大于 1px 做彩色侧边条，改用整边描边、底色填充或前导图标。",
      "不要用渐变文字（background-clip: text + gradient），强调靠字重或字号。",
      "不要用玻璃拟态（backdrop-filter 模糊卡片）当默认。",
      "不要把布局压成密不透风的文档压缩包；不要到处套一模一样的卡片网格，更不要卡中卡。",
      "不要写空洞的营销口号（DESIGNED TO SHIP FAST 之类），那是 PRODUCT.md 点名拒绝的纯营销落地页空洞包装和过度 AI 生成感的模板化卡片墙。",
      "不要用教前端工程师的课堂腔，语气要面向非前端人，直白、可执行。",
      "不要给静止的卡片挂常驻阴影（The Flat-At-Rest Rule）。",
      "不要用带 blur 的柔和投影或彩色 glow（The Hard-Shadow Rule）。"
    ]
  }
}
